# Enforce LF line endings for all text files in the repo
# regardless of the developer's OS (prevents CRLF/LF churn in diffs)
* text=auto eol=lf

# Explicitly binary — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.tar binary

# Lock files — treat as text but never diff
package-lock.json -diff
pnpm-lock.yaml -diff
yarn.lock -diff
