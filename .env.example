# ============================================================
# Meeting Intelligence Service — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to source control.

# ─── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
SERVICE_NAME=meeting-intelligence-service
LOG_LEVEL=debug

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/meeting_intelligence?schema=public

# ─── JWT Authentication ─────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=meeting-intelligence-service
JWT_AUDIENCE=meeting-intelligence-clients

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Bcrypt ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── File Upload ────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=uploads

# ─── AI / Transcription ─────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPGRAM_API_KEY=...

# ─── Redis (optional — for caching / job queues) ─────────────
# REDIS_URL=redis://localhost:6379

# ─── Email (optional) ────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# EMAIL_FROM=noreply@meetingintelligence.io
